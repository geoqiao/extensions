{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node 22",
  "include": ["src/**/*"],
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "Node16",
    "target": "es2022",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  }
}
